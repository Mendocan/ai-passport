{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-passport.dev/schemas/passport.schema.json",
  "title": "AI Passport",
  "description": "Portable user-owned identity document for AI systems. Plaintext shape; at rest each section is encrypted independently.",
  "type": "object",
  "required": ["version", "identity", "preferences", "coding", "projects", "permissions", "providers"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver version of the passport document format.",
      "examples": ["1.0.0"]
    },
    "identity": {
      "$ref": "#/$defs/identity"
    },
    "preferences": {
      "$ref": "#/$defs/preferences"
    },
    "coding": {
      "$ref": "#/$defs/coding"
    },
    "projects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/project"
      }
    },
    "permissions": {
      "$ref": "#/$defs/permissionsMeta"
    },
    "providers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/provider"
      }
    }
  },
  "$defs": {
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "display_name": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "examples": ["Software Engineer", "Designer"] },
        "timezone": { "type": "string", "examples": ["Europe/Istanbul"] },
        "locale": { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$", "examples": ["tr", "en-US"] },
        "bio": { "type": "string", "maxLength": 500 }
      }
    },
    "preferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "language": { "type": "string", "examples": ["tr", "en"] },
        "communication_style": {
          "type": "string",
          "enum": ["concise", "balanced", "detailed"]
        },
        "verbosity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "explain_before_code": { "type": "boolean" },
        "prefer_examples": { "type": "boolean" }
      }
    },
    "coding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primary_languages": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "frameworks": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "style": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "indent": { "type": "integer", "minimum": 1, "maximum": 8 },
            "quotes": { "type": "string", "enum": ["single", "double"] },
            "semicolons": { "type": "boolean" },
            "line_width": { "type": "integer", "minimum": 40, "maximum": 200 },
            "trailing_comma": { "type": "boolean" }
          }
        },
        "conventions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Free-form coding conventions the user wants AI to follow."
        },
        "ai_preferences": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "explain_before_code": { "type": "boolean" },
            "prefer_minimal_diffs": { "type": "boolean" },
            "avoid_unrequested_refactors": { "type": "boolean" },
            "match_existing_patterns": { "type": "boolean" },
            "write_tests_when_requested": { "type": "boolean" }
          }
        },
        "detected_from": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "source": { "type": "string", "enum": ["manual", "git", "github", "plugin"] },
            "path": { "type": "string" },
            "analyzed_at": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    "project": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "maxLength": 1000 },
        "status": {
          "type": "string",
          "enum": ["active", "paused", "archived"],
          "default": "active"
        },
        "stack": {
          "type": "array",
          "items": { "type": "string" }
        },
        "conventions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "repo_root": { "type": "string" },
        "repo_remote": { "type": "string", "format": "uri" },
        "started_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "permissionsMeta": {
      "type": "object",
      "description": "Metadata only; active grants live in permissions/grants.json at runtime.",
      "additionalProperties": false,
      "properties": {
        "default_policy": {
          "type": "string",
          "enum": ["deny_all"],
          "default": "deny_all"
        },
        "last_reviewed_at": { "type": "string", "format": "date-time" }
      }
    },
    "provider": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "examples": ["cursor", "claude", "chatgpt", "vscode"]
        },
        "name": { "type": "string" },
        "registered_at": { "type": "string", "format": "date-time" },
        "last_access_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
