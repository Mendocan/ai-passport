{
  "name": "@ai-passport-core/cli",
  "version": "0.1.1",
  "description": "Portable user-owned identity layer for AI systems — CLI, core API, and MCP adapter",
  "type": "module",
  "bin": {
    "ai-passport": "dist/index.js"
  },
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "clean": "node --input-type=module -e \"import fs from 'node:fs'; fs.rmSync('dist',{recursive:true,force:true})\"",
    "rebuild": "npm run clean && npm run build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "passport": "node dist/index.js",
    "prepublishOnly": "npm run rebuild && npm test",
    "prepack": "npm run rebuild",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "identity",
    "passport",
    "cursor",
    "mcp",
    "cli",
    "encryption",
    "developer-tools"
  ],
  "author": "Mendocan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mendocan/ai-passport.git"
  },
  "homepage": "https://github.com/Mendocan/ai-passport#readme",
  "bugs": {
    "url": "https://github.com/Mendocan/ai-passport/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^13.1.0",
    "keytar": "^7.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "files": [
    "dist",
    "schemas",
    "config",
    "examples",
    "plugins"
  ]
}
